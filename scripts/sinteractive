#!/bin/bash
# -*- coding: utf-8 -*-
# Original Author: Pär Andersson (National Supercomputer Centre, Sweden)
# Updated by: Jonathon Anderson (University of Colorado Boulder)
# Updated by: Jay Hesselberth
# Version: 2017-09-15
#
# This will submit a batch script that starts tmux on a node. Then
# ssh is used to connect to the node and attach the tmux session. The
# result is similar to an interactive shell in PBS (qsub -I)

TMUX_BIN='/usr/bin/tmux'
JOB_ID=''

# Convert time shorthand (e.g. 8h, 30m, 2d, 1d12h, 1h30m) to HH:MM:SS
function parse_time {
    local input="$1"

    # Already in SLURM format (contains : or D-), pass through
    if [[ "$input" =~ [:] ]] || [[ "$input" =~ ^[0-9]+-  ]]; then
        echo "$input"
        return
    fi

    # Pure integer = minutes (SLURM native)
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        echo "$input"
        return
    fi

    local days=0 hours=0 minutes=0
    local remaining="$input"

    if [[ "$remaining" =~ ^([0-9]+)d ]]; then
        days="${BASH_REMATCH[1]}"
        remaining="${remaining#*d}"
    fi
    if [[ "$remaining" =~ ^([0-9]+)h ]]; then
        hours="${BASH_REMATCH[1]}"
        remaining="${remaining#*h}"
    fi
    if [[ "$remaining" =~ ^([0-9]+)m ]]; then
        minutes="${BASH_REMATCH[1]}"
        remaining="${remaining#*m}"
    fi

    if [[ -n "$remaining" ]]; then
        echo 1>&2 "Warning: unrecognized time format '$input', passing through to SLURM"
        echo "$input"
        return
    fi

    if (( days > 0 )); then
        printf '%d-%02d:%02d:00\n' "$days" "$hours" "$minutes"
    else
        printf '%02d:%02d:00\n' "$hours" "$minutes"
    fi
}

function usage {
    cat <<EOF
Usage: sinteractive [OPTIONS] [-- SBATCH_ARGS...]
       sinteractive --attach JOBID

Start an interactive tmux session on a compute node via Slurm.

Options:
  --node NODE       Request a specific compute node (e.g., compute01)
  --partition PART  Slurm partition (default: normal)
  --time TIME       Wall time limit (default: 08:00:00)
                    Supports shorthand: 8h, 30m, 2d, 1d12h, 1h30m
  --attach JOBID    Reattach to a running sinteractive session
  -h, --help        Show this help message

All other options are passed directly to sbatch. Examples:

  sinteractive                          # 8h session, default resources
  sinteractive --node compute01         # run on a specific node
  sinteractive --time=2h -p rna          # 2h session on rna partition
  sinteractive --mem=16G --cpus-per-task=4

Reconnecting after a disconnect:

  If your SSH connection drops or you detach (Ctrl-b d), the tmux
  session keeps running. To reconnect from the login node:

  sinteractive --attach JOBID           # reattach to the session

  Use "squeue --me" to find your job ID if you don't remember it.
EOF
    exit 0
}

function main {
    if [[ "$1" == 'tmux' ]]; then
        shift
        start_tmux "$@"
        return
    elif [[ "$1" == 'attach' ]]; then
        shift
        attach_tmux "$@"
        return
    fi

    # Parse custom flags before passing remaining args to sbatch
    local args=()
    local reattach_jobid=''
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                usage
                ;;
            --attach)
                reattach_jobid="$2"
                shift 2
                ;;
            --attach=*)
                reattach_jobid="${1#--attach=}"
                shift
                ;;
            --node)
                args+=(--nodelist="$2")
                shift 2
                ;;
            --node=*)
                args+=(--nodelist="${1#--node=}")
                shift
                ;;
            --time)
                args+=(--time="$(parse_time "$2")")
                shift 2
                ;;
            --time=*)
                args+=(--time="$(parse_time "${1#--time=}")")
                shift
                ;;
            -t)
                args+=(-t "$(parse_time "$2")")
                shift 2
                ;;
            --partition)
                args+=(--partition="$2")
                shift 2
                ;;
            --partition=*)
                args+=(--partition="${1#--partition=}")
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done

    if [[ -n "${reattach_jobid}" ]]; then
        reattach "${reattach_jobid}"
    fi

    set -- "${args[@]}"

    # Default to 8 hours if no --time/-t specified
    if ! printf '%s\n' "$@" | grep -qE '^(--time|-t)'; then
        set -- --time=08:00:00 "$@"
    fi

    # Default to normal partition if no --partition/-p specified
    if ! printf '%s\n' "$@" | grep -qE '^(--partition|-p)'; then
        set -- --partition=normal "$@"
    fi

    local output
    local sbatch_ec
    output=$(sbatch "$@" "${BASH_SOURCE[0]}" tmux)
    sbatch_ec=$?

    JOB_ID=$(<<<"${output}" egrep -o -e '\b[0-9]+$')
    if [[ -z "${JOB_ID}" ]]; then
        echo 1>&2 "$0: unable to find job id in sbatch output"
        exit "$sbatch_ec"
    fi

    scontrol update JobId="${JOB_ID}" Comment="sinteractive-${JOB_ID}"

    echo 1>&2 "Interactive job with ID ${JOB_ID} submitted, please wait."
    local state
    while true; do
        sleep 5s

        # Check job status
        state=$(squeue --jobs "${JOB_ID}" --states PENDING,RUNNING --noheader --Format state | xargs)
        if [[ "${state}" == 'RUNNING' ]]; then
            break
        elif [[ "${state}" != 'PENDING' ]]; then
            echo 1>&2 "$0: job is neither RUNNING nor PENDING. Aborting."
            scancel --quiet "${JOB_ID}"
            exit 1
        fi

        echo 1>&2 -n '.'
    done

    local batchhost
    batchhost=$(squeue --jobs "${JOB_ID}" --noheader --Format batchhost | xargs)

    echo 1>&2 ''
    echo 1>&2 'Connecting to sinteractive session, please wait...'

    sleep 8s

    # sinteractive job is running and we're about to connect. From this
    # point, detaching or disconnecting should NOT cancel the job.
    trap - SIGINT SIGTERM EXIT

    ssh -X -t "${batchhost}" "${BASH_SOURCE[0]}" attach "sinteractive-${JOB_ID}"

    # Check if the sinteractive job is still running after SSH exits
    local post_state
    post_state=$(squeue --jobs "${JOB_ID}" --states RUNNING --noheader --Format state 2>/dev/null | xargs)

    if [[ "${post_state}" == 'RUNNING' ]]; then
        echo 1>&2 ''
        echo 1>&2 "Disconnected from sinteractive session."
        echo 1>&2 "Your job ${JOB_ID} is still running on ${batchhost}."
        echo 1>&2 ''
        echo 1>&2 "To reconnect:"
        echo 1>&2 "  sinteractive --attach ${JOB_ID}"
        echo 1>&2 ''
        echo 1>&2 "To cancel the job:"
        echo 1>&2 "  scancel ${JOB_ID}"
    else
        echo 1>&2 "Session ended. Job ${JOB_ID} is no longer running."
    fi
}

function reattach {
    local jobid=$1

    # Verify the job is still running
    local state
    state=$(squeue --jobs "${jobid}" --states RUNNING --noheader --Format state | xargs)
    if [[ "${state}" != 'RUNNING' ]]; then
        echo 1>&2 "$0: job ${jobid} is not running (state: ${state:-unknown})"
        exit 1
    fi

    echo 1>&2 "Reattaching to sinteractive session ${jobid}..."
    exec srun --overlap --jobid="${jobid}" --pty \
        $TMUX_BIN -u attach-session -t "sinteractive-${jobid}"
}

function start_tmux {
    export TERM=xterm-256color
    $TMUX_BIN -u new-session -d -s "sinteractive-${SLURM_JOB_ID}"
    $TMUX_BIN set-hook -t "sinteractive-${SLURM_JOB_ID}" session-closed \
        "run-shell '$TMUX_BIN wait-for -S sinteractive-done-${SLURM_JOB_ID}'"
    # Block until the tmux session is destroyed (keeps the SLURM job alive)
    $TMUX_BIN wait-for "sinteractive-done-${SLURM_JOB_ID}"
}

function attach_tmux {
    local SESSION=$1

    if [[ "$DISPLAY" != '' ]]; then
        $TMUX_BIN setenv -t "$SESSION" DISPLAY "$DISPLAY"
    fi

    exec $TMUX_BIN -u attach-session -t "$SESSION"
}

function cleanup {
    if [[ -n "${JOB_ID}" ]]; then
        scancel --quiet "${JOB_ID}"
    fi

    exit
}

trap cleanup SIGINT SIGTERM EXIT

main "$@"
